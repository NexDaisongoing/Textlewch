import psutil
import platform
import logging
import gpuinfo
import time
import datetime
from pyromod import listen
from pyrogram import Client
from pyrogram.types import Message


# Configure logging (or you can import your LOGS from a common module)
LOGS = logging.getLogger("System_Info")

def register_system_info_handler(bot: Client):
    @bot.on(listen(filters.command("systeminfo")))
    async def system_info(client: Client, message: Message):
        LOGS.info(f"Received /systeminfo command from user: {message.from_user.id}")

        try:
            LOGS.info("Fetching system details...")

            # CPU Information
            cpu_name = platform.processor()
            physical_cores = psutil.cpu_count(logical=False)
            logical_cores = psutil.cpu_count(logical=True)
            cpu_freq = psutil.cpu_freq()
            cpu_usage = psutil.cpu_percent(interval=1)

            # RAM Information
            virtual_memory = psutil.virtual_memory()
            total_ram = virtual_memory.total / (1024 ** 3)  # GB
            available_ram = virtual_memory.available / (1024 ** 3)  # GB
            used_ram = virtual_memory.used / (1024 ** 3)  # GB
            ram_usage = virtual_memory.percent

            # Storage Information
            partitions = psutil.disk_partitions()
            disk_info = ""
            for partition in partitions:
                usage = psutil.disk_usage(partition.mountpoint)
                disk_info += f"\n🔹 **{partition.device}**: {usage.percent}% used ({usage.used / (1024 ** 3):.2f} GB used / {usage.total / (1024 ** 3):.2f} GB total)"

            # GPU Information (using gpuinfo library)
            gpu_info = gpuinfo.get_info()
            if gpu_info:
                gpu_name = gpu_info[0].name
                gpu_memory = gpu_info[0].memoryTotal / (1024 ** 2)  # MB
                gpu_usage = gpu_info[0].memoryUsed / (1024 ** 2)  # MB
            else:
                gpu_name = "No GPU Detected"
                gpu_memory = 0
                gpu_usage = 0

            # System Uptime
            boot_time = psutil.boot_time()
            uptime_seconds = time.time() - boot_time
            uptime = str(datetime.timedelta(seconds=uptime_seconds))

            # Form the response
            response = (
                "🖥 **System Information**\n"
                f"🔹 **Processor**: {cpu_name}\n"
                f"🔹 **Physical Cores**: {physical_cores}\n"
                f"🔹 **Logical Cores**: {logical_cores}\n"
                f"🔹 **Max Frequency**: {cpu_freq.max:.2f} MHz\n"
                f"🔹 **Current Frequency**: {cpu_freq.current:.2f} MHz\n"
                f"🔹 **CPU Usage**: {cpu_usage}%\n\n"
                f"🔹 **Total RAM**: {total_ram:.2f} GB\n"
                f"🔹 **Used RAM**: {used_ram:.2f} GB\n"
                f"🔹 **Available RAM**: {available_ram:.2f} GB\n"
                f"🔹 **RAM Usage**: {ram_usage}%\n\n"
                f"🔹 **Disk Usage**: {disk_info}\n\n"
                f"🔹 **GPU**: {gpu_name}\n"
                f"🔹 **GPU Memory**: {gpu_memory:.2f} MB\n"
                f"🔹 **GPU Usage**: {gpu_usage:.2f} MB\n\n"
                f"🔹 **System Uptime**: {uptime}"
            )

            LOGS.info("Sending response to user...")
            await message.reply_text(response)
            LOGS.info("Response sent successfully.")

        except Exception as e:
            LOGS.error(f"Error in systeminfo command: {e}")
            await message.reply_text("❌ An error occurred while fetching system information.")